#. module: account_asset
#. odoo-python
#: code:addons/account_asset/wizard/asset_modify.py:0
#, python-format
msgid "You can't re-evaluate the asset before the lock date."
msgstr "आप लॉक तारीख से पहले ऐसेट की कीमत दोबारा तय नहीं कर सकते।"

#. module: account_asset
#. odoo-python
#: code:addons/account_asset/models/account_asset.py:0
#, python-format
msgid ""
"You cannot add or remove bills when the asset is already running or closed."
msgstr "जब ऐसेट चालू या बंद हो जाए, तो आप उससे जुड़े बिल बदल नहीं सकते।"

#. module: account_asset
#. odoo-python
#: code:addons/account_asset/models/account_asset.py:0
#, python-format
msgid "You cannot archive a record that is not closed"
msgstr "आप अधूरे रिकॉर्ड को हटा नहीं सकते"

#. module: account_asset
#. odoo-python
#: code:addons/account_asset/models/account_asset.py:0
#: code:addons/account_asset/wizard/asset_modify.py:0
#, python-format
msgid ""
"You cannot automate the journal entry for an asset that has a running gross "
"increase. Please use 'Dispose' on the increase(s)."
msgstr ""
"आप किसी ऐसी ऐसेट के लिए अपने-आप जर्नल एंट्री नहीं बना सकते जिसका मूल्य अभी भी बढ़ रहा "
"है. ऐसा करने के लिए, पहले बढ़े हुए मूल्य को 'डिस्पोज़' करें।"

#. module: account_asset
#. odoo-python
#: code:addons/account_asset/models/account_asset.py:0
#, python-format
msgid ""
"You cannot create an asset from lines containing credit and debit on the "
"account or with a null amount"
msgstr ""
"आप ऐसी एंट्री से ऐसेट नहीं बना सकते जिसमें डेबिट और क्रेडिट दोनों हों या रकम शून्य हो."

#. module: account_asset
#. odoo-python
#: code:addons/account_asset/models/account_asset.py:0
#, python-format
msgid "You cannot delete a document that is in %s state."
msgstr "आप %s स्थिति में दस्तावेज़ नहीं मिटा सकते"

#. module: account_asset
#. odoo-python
#: code:addons/account_asset/models/account_asset.py:0
#, python-format
msgid ""
"You cannot delete an asset linked to posted entries.\n"
"You should either confirm the asset, then, sell or dispose of it, or cancel "
"the linked journal entries."
msgstr ""
"जिस ऐसेट की एंट्री हो चुकी है, उसे आप सीधा नहीं मिटा सकते. \n"
"आपको या तो उसे बेचना/हटा देना चाहिए या फिर उसकी सारी पुरानी एंट्रीज़ रद्द कर दें।"

#. module: account_asset
#. odoo-python
#: code:addons/account_asset/models/account_asset.py:0
#, python-format
msgid "You cannot dispose of an asset before the lock date."
msgstr "आप लॉक तारीख से पहले ऐसेट को हटा नहीं सकते।"

#. module: account_asset
#. odoo-python
#: code:addons/account_asset/models/account_move.py:0
#, python-format
msgid "You cannot reset to draft an entry related to a posted asset"
msgstr "जिस ऐसेट की एंट्री हो चुकी है, उसे आप वापस ड्राफ्ट स्थिति में नहीं कर सकते"

#. module: account_asset
#. odoo-python
#: code:addons/account_asset/wizard/asset_modify.py:0
#, python-format
msgid "You cannot resume at a date equal to or before the pause date"
msgstr ""
"आप किसी रुकी हुई चीज़ को उसी या पिछली तारीख से दोबारा शुरू नहीं कर सकते, वह बाद की "
"तारीख से ही शुरू होगी"

