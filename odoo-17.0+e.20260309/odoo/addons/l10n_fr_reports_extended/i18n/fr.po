#. module: l10n_fr_reports_extended
#: model_terms:ir.ui.view,arch_db:l10n_fr_reports_extended.view_l10n_fr_reports_report_form
msgid ""
"<span invisible=\"vat_amount\">\n"
"                        There is no amount in your Tax report, Odoo will "
"send an empty declaration (check box \"declaration of nil\" checked)\n"
"                    </span>\n"
"                    <span invisible=\"not has_wrongly_configured_account\">\n"
"                        Some accounts are wrongly configured. For the VAT "
"declaration we need an account number and\n"
"                        the BIC code.\n"
"                    </span>\n"
"                    <span invisible=\"bank_account_line_count &lt;= 3\">\n"
"                        You can't use more than 3 accounts.\n"
"                    </span>\n"
"                    <span invisible=\"is_vat_due or computed_vat_amount "
"&gt;= vat_amount\"> The VAT amount does not match to the amount you want to "
"receive.<br/> If you proceed without matching the VAT\n"
"                        amount, the difference will be carried over to the "
"next period. </span>\n"
"                    <span invisible=\"not is_vat_due or computed_vat_amount "
"&gt;= vat_amount\">\n"
"                        The VAT amount does not match to the amount you have "
"to pay to the administration.\n"
"                    </span>"
msgstr ""

