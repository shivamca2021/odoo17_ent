<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sale_order_view_form" model="ir.ui.view">
            <field name="name">sale.order.view.form.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="l10n_br_edi_sale.order_form_inherit"/>
            <field name="arch" type="xml">
                <field name="l10n_br_edi_payment_method" position="after">
                    <field name="l10n_br_presence" invisible="country_code != 'BR'"/>
                    <field name="l10n_br_service_operation_indicator" invisible="country_code != 'BR'"/>
                </field>
            </field>
        </record>
    </data>
</odoo>
